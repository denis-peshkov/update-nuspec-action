{
  "manifestVersion": 1,
  "id": "update-nuspec",
  "publisher": "peshkov",
  "version": "1.0.0",
  "targets": [
    {
      "id": "Microsoft.VisualStudio.Services"
    }
  ],
  "scopes": [
    "vso.build"
  ],
  "contributions": [
    {
      "id": "3c4e8f2a-1b3d-4e5f-9a6b-2d8e0f1a3b4c",
      "type": "ms.vss-distributed-task.task",
      "targets": ["ms.vss-distributed-task.tasks"],
      "properties": {
        "name": "task"
      }
    }
  ],
  "repository": {
    "type": "git",
    "uri": "https://github.com/denis-peshkov/update-nuspec-action"
  },
  "public": true,
  "name": "Update *.nuspec",
  "description": "CLI to sync NuGet dependencies in *.nuspec with PackageReference versions from matching *.csproj files.",
  "categories": ["Azure Pipelines"],
  "tags": ["cli", "nuget", "nuspec", "dotnet", "csproj", "azure-pipelines", "ci"],
  "icons": {
    "default": "marketplace/extension-icon.png"
  },
  "screenshots": [
    {
      "path": "marketplace/images/example-boilerplate-url-normalizer.png"
    },
    {
      "path": "marketplace/images/example-package-json.png"
    }
  ],
  "branding": {
    "color": "rgb(244, 247, 251)",
    "theme": "light"
  },
  "content": {
    "details": {
      "path": "marketplace/overview.md"
    },
    "license": {
      "path": "marketplace/license.md"
    }
  },
  "links": {
    "home": {
      "uri": "https://github.com/denis-peshkov/update-nuspec-action"
    },
    "support": {
      "uri": "https://github.com/denis-peshkov/update-nuspec-action/issues"
    },
    "repository": {
      "uri": "https://github.com/denis-peshkov/update-nuspec-action"
    },
    "privacypolicy": {
      "uri": "https://github.com/denis-peshkov/update-nuspec-action/appendices/privacy-policy/"
    }
  },
  "files": [
    {
      "path": "task"
    },
    {
      "path": "marketplace/images",
      "addressable": true
    }
  ]
}
